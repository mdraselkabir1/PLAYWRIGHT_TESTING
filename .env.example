# Available environment variables for this test suite.
#
# These are NOT loaded automatically from a .env file.
# Set them as shell exports or inject them via your CI/CD pipeline.
#
# Usage examples:
#   Local shell:   export BASE_URL=https://staging.dsinnovators.com && npx playwright test
#   One-liner:     BASE_URL=https://staging.dsinnovators.com npx playwright test
#   GitHub Actions: set BASE_URL in the env: block of your workflow step
#
# Default (when BASE_URL is not set): https://www.dsinnovators.com
BASE_URL=https://www.dsinnovators.com
